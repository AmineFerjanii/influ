# Copy this file to .env and fill in your values before running docker compose

# --- Instagram credentials (optional) ---
# Increases scrape capacity beyond the ~10-20 unauthenticated requests per session
IG_USERNAME=
IG_PASSWORD=

# --- Scraper timing (seconds) ---
IG_MIN_DELAY=8
IG_MAX_DELAY=15

# --- CORS allowed origins ---
# In production: set to the URL your users will access (e.g. http://your-domain.com)
# Multiple values are comma-separated
ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173
